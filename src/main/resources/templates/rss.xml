			<guid isPermaLink="false" th:text="${ev.id}">7bd204c6-1655-4c27-aeee-53f933c5395f</guid>
			<pubDate th:text="${#temporals.format(ev.startDate.minusWeeks(1), 'EEE, dd LLL yyyy HH:mm:ss XX', #locale.ENGLISH)}">Sun, 6 Sep 2009 16:20:00 +0000</pubDate>
		</item>

	</channel>
